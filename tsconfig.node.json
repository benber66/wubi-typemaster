{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "electron-vite/node"]
  },
  "include": [
    "electron/**/*",
    "electron.vite.config.ts",
    "vite.web.config.ts",
    "scripts/**/*",
    "src/db/**/*",
    "src/lib/**/*",
    "src/data/**/*",
    "src/types/**/*"
  ]
}
